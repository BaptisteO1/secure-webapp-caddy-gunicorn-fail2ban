[Unit]
Description=Gunicorn Web Application
After=network.target

[Service]
User=baptiste
Group=www-data
WorkingDirectory=/home/baptiste/webapp
Environment="PATH=/home/baptiste/webapp/venv/bin"
ExecStart=/home/baptiste/webapp/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 app:app

[Install]
WantedBy=multi-user.target